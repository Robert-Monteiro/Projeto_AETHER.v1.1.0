{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=aetherlux;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Issuer": "AetherLux",
    "Audience": "AetherLuxClients",
    "Secret": "ReplaceWithStrongSecretKeyForProduction123!",
    "ExpiryMinutes": 60,
    "RefreshExpiryDays": 7
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "Agent": {
    "HeartbeatIntervalSeconds": 30,
    "WebSocketUrl": "wss://localhost:5001/agenthub"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
